# ─── Supabase ───────────────────────────────────────────────────────────────
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=<SERVICE_ROLE_KEY>    # NE PAS exposer côté client !

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Web Push / VAPID ───────────────────────────────────────────────────────
# Générer avec : npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=<VAPID_PUBLIC_KEY>
VAPID_PRIVATE_KEY=<VAPID_PRIVATE_KEY>

# ─── Tests E2E (Playwright) ─────────────────────────────────────────────────
# Compte Supabase de test (créé manuellement dans le Dashboard)
TEST_USER_EMAIL=marie@exemple.fr
TEST_USER_PASSWORD=motdepasse
PLAYWRIGHT_BASE_URL=http://localhost:3000
